# 复制为 deploy/.env 或写入 systemd / K8s Secret，勿提交真实值

# MySQL（deploy-init-db.sh 与运行时共用）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=traffic_ai
DB_PASSWORD=change_me
DB_NAME=traffic_ai

# Redis
REDIS_ADDR=127.0.0.1:6379

# 必改密钥（生产禁止使用开发默认值）
JWT_SECRET=change_me_jwt_secret_min_32_chars
AES_KEY=change_me_32_byte_aes_key!!!!!!

# 可选端口覆盖
# ADMIN_CONTROL_PORT=8083

# Gateway 紧急开关
# TRAFFIC_UPSTREAM_ENABLED=true
# TRAFFIC_CIRCUIT_ENABLED=true
# TRAFFIC_UPSTREAM_LEGACY=0
