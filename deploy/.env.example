# traffic-ai 生产环境变量模板
# 复制为 deploy/.env 或写入云托管 Secret / systemd EnvironmentFile
# 完整说明见 deploy/ENV.production.md
#
# control 与 gateway 两个服务须配置相同的 DB / Redis / JWT / AES 项

# ========== MySQL（必配）==========
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=traffic_ai
DB_PASSWORD=change_me
DB_NAME=traffic_ai

# ========== Redis（必配）==========
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=

# ========== 密钥（必配，生产禁止使用开发默认值）==========
JWT_SECRET=change_me_jwt_secret_min_32_chars
AES_KEY=change_me_32_byte_aes_key!!!!!!

# ========== 端口（可选，不设则用 YAML 默认 8080/8083/8081）==========
# 单端口：CONTROL_PORT 与 ADMIN_CONTROL_PORT 设为相同值
CONTROL_PORT=8080
ADMIN_CONTROL_PORT=8083
GATEWAY_PORT=8081

# ========== Gateway 运维开关（可选）==========
TRAFFIC_UPSTREAM_ENABLED=true
TRAFFIC_CIRCUIT_ENABLED=true
# 临时排障：跳过 Redis 启动 ping 与 /readyz 检查，并暴露 GET /debug/redis（排查完务必关闭）
# TRAFFIC_REDIS_SKIP_CHECK=1
# TRAFFIC_UPSTREAM_LEGACY=0
# TRAFFIC_VERSION=1.0.0

# ========== 以下项无环境变量，请在挂载的 config.yaml 中配置 ==========
# server.mode=release
# log.level=info
# oauth.public_base_url=https://admin.your-domain.com
# oauth.providers.openai.client_id / client_secret
# email.smtp_*（启用邮件验证码时）
# gateway.upstream.* / gateway.circuit.*（性能调优）
