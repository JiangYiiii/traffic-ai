# 生产环境配置模板 — 复制为 config.prod.yaml 后填写，勿提交含密钥的文件
# 敏感项可通过环境变量覆盖，见 docs/env-config.md 与 deploy/.env.example

server:
  control_port: 8080
  admin_control_port: 8083
  gateway_port: 8081
  mode: release

database:
  host: 127.0.0.1          # 或 DB_HOST 环境变量
  port: 3306
  user: traffic_ai
  password: ""             # 或 DB_PASSWORD 环境变量
  name: traffic_ai
  max_open_conns: 50
  max_idle_conns: 10
  conn_max_lifetime: 3600

redis:
  addr: 127.0.0.1:6379     # 或 REDIS_ADDR 环境变量
  password: ""
  db: 0
  pool_size: 20

jwt:
  secret: "CHANGE_ME_jwt_secret_min_32_chars"   # 或 JWT_SECRET
  access_ttl: 7200
  refresh_ttl: 604800

crypto:
  aes_key: "CHANGE_ME_32_byte_aes_key!!!!!!"    # 或 AES_KEY，必须 32 字节

email:
  smtp_host: ""
  smtp_port: 587
  username: ""
  password: ""
  from: "noreply@your-domain.com"

log:
  level: info
  format: json
  output: stdout
  file_path: ""

oauth:
  public_base_url: "https://admin.your-domain.com"
  providers:
    openai:
      client_id: ""
      client_secret: ""
      authorization_endpoint: "https://auth.openai.com/authorize"
      token_endpoint: "https://auth.openai.com/token"
      scopes: "openid profile"

gateway:
  upstream:
    enabled: true
    max_idle_conns: 256
    max_idle_conns_per_host: 64
    max_conns_per_host: 128
    idle_conn_timeout_sec: 90
    dial_timeout_sec: 5
    tls_handshake_timeout_sec: 10
    response_header_timeout_sec: 300
    stream_idle_timeout_sec: 60
  circuit:
    enabled: true
    error_rate_threshold: 0.5
    min_request_count: 20
    window_sec: 60
    cooldown_base_ms: 5000
    cooldown_max_ms: 60000
    success_threshold_to_close: 3
    half_open_probe_rate: 0.3
    key_ttl_sec: 600
    max_attempts: 3
